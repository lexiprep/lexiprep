# Copy to .env and adjust. Docker Compose reads this file.

# --- Postgres ---
POSTGRES_USER=lexiprep
POSTGRES_PASSWORD=lexiprep
POSTGRES_DB=lexiprep
POSTGRES_PORT=5432

# --- Server ---
SERVER_PORT=3000
NODE_ENV=development
# Used when running the server on the host. In Docker, Compose overrides this
# to point at the 'db' service.
DATABASE_URL=postgres://lexiprep:lexiprep@localhost:5432/lexiprep

# --- Auth (Better Auth) ---
# MUST be set to a strong random value in production (>= 32 chars).
BETTER_AUTH_SECRET=dev-only-insecure-secret-change-me-0123456789
BETTER_AUTH_URL=http://localhost:3000
WEB_ORIGIN=http://localhost:5173

# --- Web ---
WEB_PORT=5173

# --- Backups (prod only) ---
# The docker-compose.prod.yml `backup` sidecar dumps Postgres to Cloudflare R2 daily.
# Leave the R2 keys unset to keep it idle (dev never needs them). Reuses an existing R2
# account — just point at a bucket. Stored as <bucket>/<prefix>/<host>/<daily|monthly>/.
# BACKUP_R2_REMOTE=r2
# BACKUP_R2_BUCKET=lexiprep
# BACKUP_R2_PREFIX=db-backups
# BACKUP_R2_ACCESS_KEY_ID=
# BACKUP_R2_SECRET_ACCESS_KEY=
# BACKUP_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# BACKUP_CRON=0 3 * * *           # daily 03:00; 1st of month also lands in monthly/
# BACKUP_MIN_SIZE=1000            # bytes — a smaller dump is treated as a failure
# BACKUP_HOSTNAME=lexiprep-prod   # path segment, lets several hosts share one bucket
# BACKUP_HC_URL=                  # optional healthchecks.io URL (success + /fail ping)
